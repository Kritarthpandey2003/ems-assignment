generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Since SQLite doesn't support Enums directly via Prisma schema natively in the same way, we can still use String, or Prisma simulates it.
// Actually Prisma supports Enums natively in Postgres/MySQL but not SQLite.
// So I will convert Enums to Strings.

model Employee {
  id                 String     @id @default(uuid())
  name               String
  email              String     @unique
  phone              String?
  department         String?
  designation        String?
  salary             Float?
  joiningDate        DateTime?
  status             String     @default("ACTIVE") // ACTIVE, INACTIVE
  role               String     @default("EMPLOYEE") // SUPER_ADMIN, HR_MANAGER, EMPLOYEE
  password           String
  profileImage       String?
  
  // Soft Delete
  isDeleted          Boolean    @default(false)
  deletedAt          DateTime?

  // Hierarchy
  reportingManagerId String?
  reportingManager   Employee?  @relation("EmployeeToManager", fields: [reportingManagerId], references: [id])
  reportees          Employee[] @relation("EmployeeToManager")

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}
